# ============================================================================
# SLUICE — environment variables (copy to .env.local and fill in)
# Rule: ONLY NEXT_PUBLIC_* is exposed to the browser. Private keys / API keys
# must NEVER be prefixed NEXT_PUBLIC_. (See CLAUDE.md rule 12.)
# ============================================================================

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Wallet · Reown AppKit (REQUIRED for wallet connect) ─────────────────────
# Free Project ID from https://cloud.reown.com → create a project → copy "Project ID".
# Without this the wallet modal silently fails (see CLAUDE.md anticipated bugs).
NEXT_PUBLIC_REOWN_PROJECT_ID=

# ─── Arc chain (network-agnostic — packages/chain reads these) ───────────────
# These have safe built-in defaults; override only to use a provider key or another network.
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
# Optional ordered backup RPCs (comma-separated, same chain). Keep Arc primary.
ARC_RPC_FALLBACKS=
# Optional provider key for an Alchemy backup RPC.
ALCHEMY_ARC_KEY=

# Verified Arc-testnet contract addresses (override only if Circle changes them).
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
NEXT_PUBLIC_ARC_GATEWAY_DOMAIN=26
GATEWAY_API_URL=https://gateway-api-testnet.circle.com

# ─── Circle · user-controlled wallets + CLI (later phases) ───────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_APP_ID=
NEXT_PUBLIC_CIRCLE_APP_ID=

# ─── Protocol wallets · apps/api + apps/agent (generated, later phases) ──────
# Generate with the wallet script; NEVER commit real keys. NEVER NEXT_PUBLIC_.
SELLER_ADDRESS=
SELLER_PRIVATE_KEY=
BUYER_ADDRESS=
BUYER_PRIVATE_KEY=

# ─── Database · meter ledger / receipts / registry (later phases) ────────────
# Either a direct Postgres URL...
DATABASE_URL=
# ...or Supabase:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Agent · apps/agent (later phases) ───────────────────────────────────────
# Without OPENAI_API_KEY the agent runs in deterministic MOCK mode (never crashes).
OPENAI_API_KEY=
AGENT_MODEL=gpt-4o-mini
AGENT_MAX_STEPS=12
AGENT_USD_BUDGET=1.00

# ─── API server · apps/api ───────────────────────────────────────────────────
API_PORT=3001
# Comma-separated allowed CORS origins for the API.
API_CORS_ORIGINS=http://localhost:3000
